name: ci

# Enterprise CI gate for {{PROJECT_NAME}}, generated by EADOS.
# Implements the quality bar in AGENTS.md §10 across the toolchain matrix from the
# language profile. The build/test/format/lint commands come from project.yaml; the
# setup steps and language-specific extra jobs come from the profile.

on:
  pull_request:
  push:
    branches: [{{DEFAULT_BRANCH}}]
  workflow_call:

permissions:
  contents: read

# Cancel superseded runs on a PR; never cancel a run on {{DEFAULT_BRANCH}} (its history matters).
concurrency:
  group: ${{ github.workflow }}-${{ github.ref }}
  cancel-in-progress: ${{ github.event_name == 'pull_request' }}

jobs:
  # ---------------------------------------------------------------------------
  # Cross-platform build + test matrix (from the language profile).
  # ---------------------------------------------------------------------------
  build:
    name: build / ${{ matrix.os }} / ${{ matrix.toolchain }} / ${{ matrix.preset }}
    runs-on: ${{ matrix.os }}
    timeout-minutes: 30
    strategy:
      fail-fast: false
      matrix:
        include:
{{#EACH_CI_CELL}}          - { os: {{os}}, toolchain: {{toolchain}}, preset: {{preset}} }
{{/EACH_CI_CELL}}    steps:
      - name: Check out the source tree
        uses: actions/checkout@9c091bb21b7c1c1d1991bb908d89e4e9dddfe3e0 # v7.0.0

      {{CI_SETUP_STEPS}}

      - name: Build
        shell: bash
        run: {{CMD_BUILD}}

      - name: Test
        shell: bash
        run: {{CMD_TEST}}

  # ---------------------------------------------------------------------------
  # Cross-artifact congruence — the agent-runnable consistency lint.
  # ---------------------------------------------------------------------------
  consistency:
    name: consistency / lint
    runs-on: ubuntu-24.04
    timeout-minutes: 15
    steps:
      - uses: actions/checkout@9c091bb21b7c1c1d1991bb908d89e4e9dddfe3e0 # v7.0.0
        with:
          fetch-depth: 0          # i18n/version checks need full history
      - uses: actions/setup-python@ece7cb06caefa5fff74198d8649806c4678c61a1 # v6.3.0
        with:
          python-version: '3.12'
      - name: Run the consistency lint
        run: python tools/consistency_lint.py

  # ---------------------------------------------------------------------------
  # Language-specific quality jobs (format, lint, sanitizers, …) from the profile.
  # ---------------------------------------------------------------------------
  {{CI_EXTRA_JOBS}}
{{#IF_BENCH}}
  # Reproducible performance gate — runs only when the project has a benchmark suite.
  benchmark:
    name: benchmark / reproducible perf
    runs-on: ubuntu-24.04
    timeout-minutes: 30
    steps:
      - uses: actions/checkout@9c091bb21b7c1c1d1991bb908d89e4e9dddfe3e0 # v7.0.0
      {{CI_SETUP_STEPS}}
      - name: Run the benchmark suite
        shell: bash
        run: {{CMD_BENCH}}
{{/IF_BENCH}}
{{#IF_THREADING}}
  # Data-race / concurrency gate — runs only when the project exposes concurrency.
  {{CI_RACE_JOB}}
{{/IF_THREADING}}
