# Python tooling artifacts (consistency_lint, eados_lint, render)
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/

# Per-run project manifest: filled from project.yaml.template for one generation run,
# it is transient working state and must not be version-controlled in the factory.
/.eados-core/orchestrator/project.yaml

# Claude Code personal settings — .claude/ is partially TRACKED since #239 (the command
# adapters), so this must be ignored here, not left to a machine's global ignore: a stray
# `git add .claude` would otherwise stage private settings straight into the release bundle.
# (The generated repos' gitignore template already carries the same line.)
.claude/settings.local.json

# OS / editor noise
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
