name: release

# Release workflow for {{PROJECT_NAME}}, generated by EAAO.
# Fires on an annotated SemVer tag push and prepares a *draft* GitHub Release. Publishing is
# the deliberate human checkpoint (AGENTS.md §11 / docs/workflow/release.md) — this workflow
# never publishes, it only drafts so a maintainer can review and press "Publish".

on:
  push:
    tags: ["v*.*.*"]

permissions:
  contents: write

# Serialize per-tag, but NEVER cancel an in-flight release — a half-run publish is worse
# than a queued one.
concurrency:
  group: release-${{ github.ref }}
  cancel-in-progress: false

jobs:
  draft-release:
    name: draft GitHub Release for ${{ github.ref_name }}
    runs-on: ubuntu-24.04
    timeout-minutes: 30
    steps:
      - name: Check out the tagged tree
        uses: actions/checkout@9f698171ed81b15d1823a05fc7211befd50c8ae0 # v6.0.3
        with:
          fetch-depth: 0

      {{CI_SETUP_STEPS}}

      - name: Build (verify the tag builds clean)
        shell: bash
        run: {{CMD_BUILD}}

      - name: Draft the release (a human publishes it)
        uses: softprops/action-gh-release@3bb12739c298aeb8a4eeaf626c5b8d85266b0e65 # v2.6.2
        with:
          draft: true
          generate_release_notes: true
        env:
          GITHUB_TOKEN: ${{ secrets.GITHUB_TOKEN }}
